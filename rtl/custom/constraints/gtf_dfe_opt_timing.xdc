# GTF DFE Optimization - Timing Constraints
#
# Apply these constraints in your Vivado project alongside the
# board-level constraints. Adjust clock names to match your design.

# ============================================================
# Clock domain declarations
# ============================================================

# Core clock (from PCIe or board oscillator, typically 250 MHz)
# This should already be defined in your board constraints.
# create_clock -period 4.000 -name clk_core [get_pins ...]

# DRP clock — can be same as core or separate
# If using a dedicated DRP clock:
# create_clock -period 10.000 -name drp_clk [get_pins ...]

# GTF TXUSRCLK — derived from GT reference, ~644 MHz for 10G
# This is generated by the GTF and should be auto-derived.
# create_clock -period 1.552 -name txusrclk [get_pins ...]

# GTF RXUSRCLK — recovered clock, ~644 MHz for 10G
# create_clock -period 1.552 -name rxusrclk [get_pins ...]

# ============================================================
# Clock domain crossing constraints
# ============================================================

# If DRP clock is separate from core clock:
# set_clock_groups -asynchronous \
#     -group [get_clocks clk_core] \
#     -group [get_clocks drp_clk]

# TXUSRCLK and core clock are asynchronous
# set_clock_groups -asynchronous \
#     -group [get_clocks clk_core] \
#     -group [get_clocks txusrclk]

# RXUSRCLK and core clock are asynchronous
# set_clock_groups -asynchronous \
#     -group [get_clocks clk_core] \
#     -group [get_clocks rxusrclk]

# ============================================================
# False paths for CDC synchronizers
# ============================================================

# DMONITOROUT is sampled asynchronously — constrain the synchronizer
set_false_path -to [get_cells -hierarchical -filter {NAME =~ *gtf_dfe_opt_core*dmonitorout_sync*}]

# Tap hold/ovrden outputs are quasi-static (change only during calibration)
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *cal_fsm*tap_hold_ovrden*}]

# RXLPMEN is quasi-static
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *lpm_dfe_sel*rxlpmen*}]

# FCS control ports are quasi-static
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *fcs_bypass*ctl_rx_*}]
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *fcs_bypass*ctl_tx_*}]

# Buffer bypass control signals (quasi-static after init)
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *buf_bypass*txphalignen*}]
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *buf_bypass*rxphalignen*}]

# ============================================================
# TX Alignment Engine (runs in TXUSRCLK domain)
# ============================================================

# Statistics counters are read asynchronously by the core clock domain
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *tx_align*align_hit_count*}] \
               -to [get_cells -hierarchical -filter {NAME =~ *gtf_dfe_opt_core*axil_rdata*}]
set_false_path -from [get_cells -hierarchical -filter {NAME =~ *tx_align*align_miss_count*}] \
               -to [get_cells -hierarchical -filter {NAME =~ *gtf_dfe_opt_core*axil_rdata*}]

# ============================================================
# Eye scan BRAM
# ============================================================

# BRAM read port is accessed from the core clock domain,
# write port from the eye scan FSM (also core clock).
# No CDC needed if both ports share the same clock.

# ============================================================
# Max delay constraints for DRP path
# ============================================================

# DRP transactions should complete within a reasonable number of cycles
# set_max_delay -datapath_only 20.0 \
#     -from [get_cells -hierarchical -filter {NAME =~ *drp_ctrl*drp_addr*}] \
#     -to [get_ports gtf_drp_addr*]

# ============================================================
# Physical constraints (optional, for better timing closure)
# ============================================================

# Keep DFE optimization logic near the GTF transceiver tile
# create_pblock pblock_gtf_dfe
# add_cells_to_pblock pblock_gtf_dfe [get_cells -hierarchical -filter {NAME =~ *gtf_dfe_opt_core*}]
# resize_pblock pblock_gtf_dfe -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y1}
